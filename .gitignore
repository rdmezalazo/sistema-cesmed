# ============================================================
# SISTEMA CESMED — .gitignore
# Stack: React + TypeScript + Vite + Supabase + Tailwind + Playwright
# ============================================================

# ─── Dependencias ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Salida de build ────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ─── Variables de entorno (¡NO subir claves!) ───────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging

# ─── Vite ───────────────────────────────────────────────────
vite.config.ts.timestamp-*
*.local

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# ─── Testing — Playwright ───────────────────────────────────
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/

# ─── Testing — Vitest / Coverage ────────────────────────────
coverage/
.nyc_output/

# ─── Supabase local ─────────────────────────────────────────
supabase/.branches/
supabase/.temp/
supabase/functions/.env

# ─── Caché y archivos temporales ────────────────────────────
.cache/
.turbo/
.eslintcache
.stylelintcache
*.tmp
*.temp

# ─── Lock files (mantener sólo uno por equipo) ──────────────
# Se conserva bun.lockb (Bun) y package-lock.json (npm).
# Descomenta la línea correspondiente si sólo usas un gestor:
# bun.lockb
# bun.lock
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ─── Editores e IDEs ─────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
.project
.classpath

# ─── Sistema Operativo ──────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ─── Archivos de imagen del editor Pintura (licencia) ───────
# Evitar subir licencias privadas si las hubiera
*.pintura-license

# ─── Misc ───────────────────────────────────────────────────
*.pem
*.key
*.cert
*.p12
